# Gate C 本機範本（複製所需列至 `.env`；勿 commit 真實密碼）
# 對照：docs/gate-c-go-live-signoff-draft-2026-05-15.md §3、npm run gatec:preflight

# --- 必填：真庫 Playwright 主路徑 ---
# E2E_AUTH_EMAIL=teamlead@your-staging.example
# E2E_AUTH_PASSWORD=

# --- 建議：user-role-admin + system-settings P2 ---
# E2E_AUTH_ADMIN_EMAIL=admin@your-staging.example
# E2E_AUTH_ADMIN_PASSWORD=
# E2E_AUTH_STAFF_EMAIL=staff@your-staging.example
# E2E_AUTH_STAFF_PASSWORD=
# E2E_AUTH_TEAMLEAD_EMAIL=teamlead@your-staging.example
# E2E_AUTH_TEAMLEAD_PASSWORD=

# --- 人工完成後標記（僅本機 .env；勿入版控）---
# GATE_C_PAT_DONE=1
# GATE_C_SIGNOFF_DONE=1
